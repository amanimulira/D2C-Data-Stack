# Copy this file to ~/.dbt/profiles.yml (or set DBT_PROFILES_DIR to this directory).
# Then choose a target by passing --target snowflake or --target duckdb.

d2c_stack:
  target: duckdb

  outputs:

    # ------------------------------------------------------------------
    # Local: zero-config, runs in-process. Used by CI and for the demo.
    # ------------------------------------------------------------------
    duckdb:
      type: duckdb
      path: "{{ env_var('DBT_DUCKDB_PATH', 'd2c_stack.duckdb') }}"
      threads: 4

    # ------------------------------------------------------------------
    # Production: Snowflake. Uses key-pair auth in CI, password locally.
    # ------------------------------------------------------------------
    snowflake:
      type: snowflake
      account:   "{{ env_var('SNOWFLAKE_ACCOUNT') }}"
      user:      "{{ env_var('SNOWFLAKE_USER') }}"
      password:  "{{ env_var('SNOWFLAKE_PASSWORD') }}"
      role:      "{{ env_var('SNOWFLAKE_ROLE',      'TRANSFORMER') }}"
      warehouse: "{{ env_var('SNOWFLAKE_WAREHOUSE', 'TRANSFORMING_WH') }}"
      database:  "{{ env_var('SNOWFLAKE_DATABASE',  'ANALYTICS') }}"
      schema:    "{{ env_var('SNOWFLAKE_SCHEMA',    'DBT_DEV') }}"
      threads: 8
      client_session_keep_alive: false
      query_tag: dbt-d2c-stack
